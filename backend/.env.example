# OpenAI (your platform key — customers do not supply keys in v1)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Database
# Local dev:
DATABASE_URL=sqlite:///./app.db
# Production (Neon / Supabase / Render Postgres — survives redeploys):
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# App
APP_NAME=Post Generator
DEBUG=true

# Platform admin (promoted on API startup if user exists)
PLATFORM_ADMIN_EMAIL=demo@example.com

# OAuth — public URLs (use https:// in production)
# API:  https://api.kj-solution.com   → privacy at /privacy
# App:  https://kjsolutioncontentgenerator.streamlit.app
APP_PUBLIC_URL=http://127.0.0.1:8001
DASHBOARD_URL=http://localhost:8501
# Production:
# APP_PUBLIC_URL=https://api.kj-solution.com
# DASHBOARD_URL=https://kjsolutioncontentgenerator.streamlit.app

# LinkedIn (https://www.linkedin.com/developers/apps)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Facebook / Meta (https://developers.facebook.com/apps)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Optional Fernet key for encrypting stored platform tokens (generate with cryptography.fernet.Fernet.generate_key())
OAUTH_TOKEN_ENCRYPTION_KEY=
